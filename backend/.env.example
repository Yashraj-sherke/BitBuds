NODE_ENV=development
PORT=5000
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Current Express/Mongoose prototype.
MONGODB_URI=mongodb://localhost:27017/bitbuds
MONGODB_URI_TEST=mongodb://localhost:27017/bitbuds-test

# Target Prisma/PostgreSQL backend.
DATABASE_URL=postgresql://bitbuds:bitbuds_dev_password@localhost:5432/bitbuds?schema=public

# Redis works for both the current backend and the target NestJS design.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
ENABLE_REDIS=false

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=debug
