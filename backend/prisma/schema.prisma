generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum UserRole {
  PARENT
  ADMIN
}

enum ProgressStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

enum XpReason {
  CHAPTER_COMPLETE
  QUIZ_SCORE
  DAILY_MISSION
  BADGE_BONUS
}

model User {
  id                   String        @id @default(uuid()) @db.Uuid
  email                String        @unique @db.VarChar(320)
  passwordHash         String?       @map("password_hash")
  googleId             String?       @unique @map("google_id")
  authProvider         AuthProvider  @default(EMAIL) @map("auth_provider")
  role                 UserRole      @default(PARENT)
  emailVerified        Boolean       @default(false) @map("email_verified")
  refreshTokenHash     String?       @map("refresh_token_hash")
  refreshTokenExpiresAt DateTime?    @map("refresh_token_expires_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  lastLoginAt          DateTime?     @map("last_login_at")

  heroProfiles HeroProfile[]

  @@index([authProvider])
  @@map("users")
}

model HeroProfile {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  heroName       String   @map("hero_name") @db.VarChar(40)
  age            Int
  activeAvatarId String?  @map("active_avatar_id") @db.Uuid
  currentLevel   Int      @default(1) @map("current_level")
  cachedTotalXp  Int      @default(0) @map("cached_total_xp")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeAvatar          Avatar?            @relation("ActiveAvatar", fields: [activeAvatarId], references: [id], onDelete: SetNull)
  avatarUnlocks         HeroAvatarUnlock[]
  progress              Progress[]
  xpEvents              XpEvent[]
  heroBadges            HeroBadge[]
  quizAttempts          QuizAttempt[]
  dailyMissionClaims    DailyMissionClaim[]

  @@index([userId])
  @@index([cachedTotalXp])
  @@map("hero_profiles")
}

model Avatar {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @unique @db.VarChar(80)
  imageUrl          String   @map("image_url")
  unlockRequirement Json     @map("unlock_requirement")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  activeForHeroes HeroProfile[]      @relation("ActiveAvatar")
  unlocks         HeroAvatarUnlock[]

  @@map("avatars")
}

model HeroAvatarUnlock {
  heroProfileId String   @map("hero_profile_id") @db.Uuid
  avatarId      String   @map("avatar_id") @db.Uuid
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  heroProfile HeroProfile @relation(fields: [heroProfileId], references: [id], onDelete: Cascade)
  avatar      Avatar      @relation(fields: [avatarId], references: [id], onDelete: Restrict)

  @@id([heroProfileId, avatarId])
  @@index([avatarId])
  @@map("hero_avatar_unlocks")
}

model World {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @db.VarChar(120)
  description       String
  order             Int
  unlockRequirement Json     @map("unlock_requirement")
  thumbnailUrl      String   @map("thumbnail_url")
  isPublished       Boolean  @default(false) @map("is_published")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  chapters Chapter[]

  @@unique([order])
  @@index([isPublished, order])
  @@map("worlds")
}

model Chapter {
  id             String   @id @default(uuid()) @db.Uuid
  worldId        String   @map("world_id") @db.Uuid
  name           String   @db.VarChar(140)
  order          Int
  storyContent   Json     @map("story_content")
  activityConfig Json     @map("activity_config")
  quizConfig     Json     @map("quiz_config")
  xpReward       Int      @default(50) @map("xp_reward")
  isPublished    Boolean  @default(false) @map("is_published")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  world        World         @relation(fields: [worldId], references: [id], onDelete: Restrict)
  progress     Progress[]
  quizAttempts QuizAttempt[]

  @@unique([worldId, order])
  @@index([worldId, isPublished, order])
  @@map("chapters")
}

model Progress {
  id                String         @id @default(uuid()) @db.Uuid
  heroProfileId     String         @map("hero_profile_id") @db.Uuid
  chapterId         String         @map("chapter_id") @db.Uuid
  status            ProgressStatus @default(LOCKED)
  completionPercent Int            @default(0) @map("completion_percent")
  bestScore         Int?           @map("best_score")
  startedAt         DateTime?      @map("started_at")
  completedAt       DateTime?      @map("completed_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  heroProfile HeroProfile @relation(fields: [heroProfileId], references: [id], onDelete: Cascade)
  chapter     Chapter     @relation(fields: [chapterId], references: [id], onDelete: Restrict)

  @@unique([heroProfileId, chapterId])
  @@index([heroProfileId, status])
  @@index([chapterId])
  @@map("progress")
}

model XpEvent {
  id            String   @id @default(uuid()) @db.Uuid
  heroProfileId String   @map("hero_profile_id") @db.Uuid
  amount        Int
  reason        XpReason
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  heroProfile HeroProfile @relation(fields: [heroProfileId], references: [id], onDelete: Cascade)

  @@index([heroProfileId, createdAt(sort: Desc)])
  @@index([reason, createdAt(sort: Desc)])
  @@map("xp_events")
}

model Badge {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(120)
  description String
  iconUrl     String   @map("icon_url")
  unlockRule  Json     @map("unlock_rule")
  xpBonus     Int      @default(0) @map("xp_bonus")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  heroBadges HeroBadge[]

  @@index([isActive])
  @@map("badges")
}

model HeroBadge {
  heroProfileId String   @map("hero_profile_id") @db.Uuid
  badgeId       String   @map("badge_id") @db.Uuid
  earnedAt      DateTime @default(now()) @map("earned_at")

  heroProfile HeroProfile @relation(fields: [heroProfileId], references: [id], onDelete: Cascade)
  badge       Badge       @relation(fields: [badgeId], references: [id], onDelete: Restrict)

  @@id([heroProfileId, badgeId])
  @@index([badgeId])
  @@map("hero_badges")
}

model QuizAttempt {
  id            String   @id @default(uuid()) @db.Uuid
  heroProfileId String   @map("hero_profile_id") @db.Uuid
  chapterId     String   @map("chapter_id") @db.Uuid
  answers       Json
  score         Int
  createdAt     DateTime @default(now()) @map("created_at")

  heroProfile HeroProfile @relation(fields: [heroProfileId], references: [id], onDelete: Cascade)
  chapter     Chapter     @relation(fields: [chapterId], references: [id], onDelete: Restrict)

  @@index([heroProfileId, chapterId, createdAt(sort: Desc)])
  @@index([chapterId, score(sort: Desc)])
  @@map("quiz_attempts")
}

model DailyMission {
  id          String   @id @default(uuid()) @db.Uuid
  missionDate DateTime @unique @map("mission_date") @db.Date
  title       String   @db.VarChar(140)
  description String
  xpReward    Int      @map("xp_reward")
  config      Json
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  claims DailyMissionClaim[]

  @@index([isPublished, missionDate])
  @@map("daily_missions")
}

model DailyMissionClaim {
  heroProfileId  String   @map("hero_profile_id") @db.Uuid
  dailyMissionId String   @map("daily_mission_id") @db.Uuid
  completedAt    DateTime @default(now()) @map("completed_at")

  heroProfile  HeroProfile  @relation(fields: [heroProfileId], references: [id], onDelete: Cascade)
  dailyMission DailyMission @relation(fields: [dailyMissionId], references: [id], onDelete: Restrict)

  @@id([heroProfileId, dailyMissionId])
  @@index([dailyMissionId])
  @@map("daily_mission_claims")
}
